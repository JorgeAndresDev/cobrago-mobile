{
  "expo": {
    "name": "CobraGo",
    "slug": "cobrago-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#072a1e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jorgeandres.cobrago"
    },
    "android": {
      "package": "com.jorgeandres.cobrago",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#072a1e"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ddc47356-3787-49f8-af63-6582e8130fc1"
      }
    },
    "owner": "jotadev07"
  }
}
